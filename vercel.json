{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/suporte",
      "status": 307,
      "headers": {
        "Location": "https://wa.me/5585988608620"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/((?!api|clientes|sucesso|falha|pendente|index|favicon)[^/.]+)",
      "dest": "/index.html"
    }
  ]
}
